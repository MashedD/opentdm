CONFIG_WINDOWS = 1
CONFIG_32BIT = 1

TARGET = gamex86.dll

CC = i686-w64-mingw32-gcc
LD = i686-w64-mingw32-gcc
WINDRES = i686-w64-mingw32-windres

CFLAGS = -std=gnu99 -static -static-libgcc -DCURL_STATICLIB -DHAVE_CURL -DWIN32 -D__USE_W32_SOCKETS # -D_WIN32_WINNT=0x0501
LDFLAGS = -shared -static -static-libgcc

LIBS = -L/usr/i686-w64-mingw32/lib

# curl and its deps (only ones we know exist)
LIBS += /usr/i686-w64-mingw32/lib/libcurl.a
LIBS += /usr/i686-w64-mingw32/lib/libnghttp2.a
LIBS += /usr/i686-w64-mingw32/lib/libpsl.a
LIBS += /usr/i686-w64-mingw32/lib/libidn2.a
LIBS += /usr/i686-w64-mingw32/lib/libbrotlidec.a
LIBS += /usr/i686-w64-mingw32/lib/libbrotlicommon.a
LIBS += /usr/i686-w64-mingw32/lib/libzstd.a
LIBS += /usr/i686-w64-mingw32/lib/libunistring.a

# ssh2 (needs zlib)
LIBS += /usr/i686-w64-mingw32/lib/libssh2.a
LIBS += /usr/i686-w64-mingw32/lib/libz.a

# OpenSSL (ssl first, then crypto)
LIBS += /usr/i686-w64-mingw32/lib/libssl.a
LIBS += /usr/i686-w64-mingw32/lib/libcrypto.a

# windows / misc helpers
LIBS += /usr/i686-w64-mingw32/lib/libcrypt32.a
LIBS += /usr/i686-w64-mingw32/lib/libwldap32.a
LIBS += /usr/i686-w64-mingw32/lib/libiconv.a
LIBS += /usr/i686-w64-mingw32/lib/libbcrypt.a

